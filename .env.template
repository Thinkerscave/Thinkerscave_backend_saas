# ============================================================================
# Environment Variables Template
# Copy this file to .env and fill in your actual values
# ============================================================================

# ===== DATABASE CONFIGURATION =====
DB_URL=jdbc:postgresql://localhost:5432/thinkerscave_saas
DB_USERNAME=postgres
DB_PASSWORD=your_secure_database_password_here

# ===== JWT CONFIGURATION =====
# Secret must be at least 256 bits (32 characters) for HS256 algorithm
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_minimum_256_bits_base64_encoded_here
# Expiration in milliseconds (3600000 = 1 hour)
JWT_EXPIRATION=3600000

# ===== MAIL CONFIGURATION =====
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
# For Gmail, use App Password: https://support.google.com/accounts/answer/185833
MAIL_PASSWORD=your_app_password_here

# ===== SERVER CONFIGURATION =====
SERVER_PORT=8181

# ===== SPRING PROFILE =====
# Options: dev, test, staging, prod
SPRING_PROFILES_ACTIVE=dev

# ============================================================================
# PRODUCTION DEPLOYMENT NOTES:
# ============================================================================
# 1. NEVER commit .env file to version control
# 2. Use strong, unique passwords for each environment
# 3. Rotate JWT secret regularly in production
# 4. Use secrets management service (AWS Secrets Manager, Azure Key Vault, etc.)
# 5. Set SPRING_PROFILES_ACTIVE=prod for production deployments
# ============================================================================
